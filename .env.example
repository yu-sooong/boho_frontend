# API 基底（開發時可用 Vite proxy `/api`，此處可留空）
# VITE_API_BASE=/api

# 正式站網域（SEO og:url、分享連結、index.html OG 注入）
# Cloudflare Pages／Workers 預覽請設成實際公開網址，例如：
# VITE_SITE_URL=https://boho-frontend.sscode543.workers.dev
VITE_SITE_URL=https://boho.yujii.app

# 正式 API（Cloudflare Pages 建置時必填完整 URL）
# VITE_API_BASE=https://api.yujii.app/api

# 對外聯絡信箱（尚未申請信箱前可先用此預設，申請後改這裡即可）
VITE_CONTACT_EMAIL=yujiiii543@gmail.com

# Google Analytics 4 Measurement ID（未設定則不載入 GA）
# 申請：https://analytics.google.com → 建立 GA4 資源 → 取得 G-XXXXXXXX
# 正式站設好後，即時報表可驗證 page_view／search_schools／submit_review 等事件
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
